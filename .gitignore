*.o
*.d
*.a
*.tmp
core
*.core
*.gmon
*~
*.swp
.DS_Store
# macOS debug-info bundles (produced alongside any compiled binary)
*.dSYM/
# Generated LLVM textual IR (dumped by -b / IFA_LLVM=1 / -t); never a fixture
*.ll

# Generated headers / cat-pages from LICENSE
LICENSE.i
COPYRIGHT.i
pyc.cat
*.cat

# Generated parsers (regenerated by `make` via make_dparser)
*.g.d_parser.cc
*.g.d_parser.h
*.g.d_parser.d
*.g.d_parser.o

# Compiled binaries / driver outputs
/pyc
/hello_world
/hello_world.py.c
/hello_world.py.s
/ifa/ifa
/ifa/ifa-test

# Compiled C output from pyc compilations at repo root
/*.py.c

# Profiling / debug output
callgrind.out.*
perf.data*
/if1.code
/log/

# Test outputs --------------------------------------------------------------
# New test runs write everything to tests/build/; old-style in-place outputs
# (still produced by some manual invocations) are also covered. Compiled test
# binaries (no extension; next to <name>.py) are covered by the broad ignore
# + negation below rather than a per-test-name whitelist, so newly added
# tests don't need a matching .gitignore edit to stay untracked. tests/empty
# is an intentional 0-byte fixture; tests/ir/ holds real fixtures. The
# specific patterns after re-ignore generated files that contain a dot (so
# the blanket negation doesn't resurrect them).
tests/*
!tests/*.*
!tests/empty
!tests/ir/
tests/build/
tests/__pycache__/
tests/pyc_compat.py
tests/*.out
tests/*.py.c
tests/*.py.s
tests/*.ll
tests/*.o
tests/*.dSYM/

# IFA library's own test outputs (its Makefile already cleans most of these).
# Compiled V-language test binaries (no extension, next to <name>.v) are
# covered by the broad ignore + negation; ir/ and synthetic/ hold real
# fixtures and stay tracked; the specific patterns below re-ignore generated
# files that happen to contain a dot (so the blanket negation doesn't
# resurrect them).
ifa/tests/*
!ifa/tests/*.*
!ifa/tests/ir/
!ifa/tests/synthetic/
ifa/tests/*.out
ifa/tests/*.c
ifa/tests/*.s
ifa/tests/*.code
ifa/tests/*.ll
ifa/tests/*.o
ifa/tests/*.dSYM/
ifa/log/
ifa/test_llvm
ifa/test_llvm.ll
ifa/test_llvm.o
ifa/make_cast_code
ifa/if1/make_cast_code
ifa/make_prims
# IFA's cast tables: cast_code.cc is committed, check_cast.cc regenerates
ifa/if1/check_cast.cc

# Editor / IDE
.vscode/
.idea/
*.iml

# Python
__pycache__/
*.pyc
*.pyo

