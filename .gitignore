/*.py.c

# Profiling / debug output
callgrind.out.*
perf.data*
/if1.code
/log/

# Test outputs --------------------------------------------------------------
# New test runs write everything to tests/build/; old-style in-place outputs
# (still produced by some manual invocations) are also covered.
tests/build/
tests/__pycache__/
tests/pyc_compat.py
tests/*.out
tests/*.py.c
tests/*.py.s

# Test binaries (no extension; compiled next to <name>.py).
# Listed as a directory-scoped negation so we don't accidentally ignore
# fixture files like `empty` that legitimately have no extension.
# These are short-lived and removed by `test_pyc` on success.
/tests/arithmetic_ops
/tests/attr_augmented_assign
/tests/basic_function
/tests/bitwise_operators
/tests/break_continue
/tests/builtins
/tests/chained_comparison
/tests/class_attr_mutation
/tests/class_attributes
/tests/class_definition_order
/tests/class_inheritance
/tests/class_inherited_attrs
/tests/class_init
/tests/conditional
/tests/default_args
/tests/dict_basic
/tests/fibonacci
/tests/for_over_range
/tests/lambda_class_attr
/tests/pyc_compat

# IFA library's own test outputs (its Makefile already cleans most of these)
ifa/tests/*.out
ifa/tests/*.c
ifa/tests/*.s
ifa/tests/*.code
ifa/log/
ifa/test_llvm
ifa/test_llvm.ll
ifa/test_llvm.o
ifa/make_cast_code
ifa/if1/make_cast_code
ifa/make_prims
# IFA's cast tables: cast_code.cc is committed, check_cast.cc regenerates
ifa/if1/check_cast.cc

