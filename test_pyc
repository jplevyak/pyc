#!/bin/bash
# End-to-end test suite for pyc.
#
# Usage: ./test_pyc [options] [pattern]
#
#   -v, --verbose       show all test results (default: only failures + summary)
#   -k, --keep          keep tests/build/ after run
#   -b, --bail          stop at first failure
#       --no-cpython    skip CPython cross-verify
#   -t, --timeout N     per-step timeout in seconds (default: 60)
#   -h, --help          this help
#
#   pattern             only run tests whose name matches *pattern*
#
# Env:
#   PYC        path to pyc binary             (default: ./pyc)
#   PYC_FLAGS  flags prepended to every pyc call (e.g. -b for LLVM)
#   PYTHON     CPython interpreter            (default: python3)
#   VALGRIND   wrapper for compile + execute  (e.g. 'valgrind -q')
#   TIMEOUT    per-step timeout in seconds    (default: 60)
#
# Sidecar conventions per test foo.py:
#   foo.py.flags                extra pyc CLI flags
#   foo.py.check                expected compile-time stdout
#   foo.py.exec.check           expected runtime stdout
#   foo.py.python.expect_fail   CPython produces different output (OK)
#   foo.py.expect_fail          pyc is expected to fail compilation
#   foo.py.check_fail           pyc may fail; counted as pass either way
#   foo.py.ignore               skip this test

set -o pipefail

PYC="${PYC:-./pyc}"
PYTHON="${PYTHON:-python3}"
VALGRIND="${VALGRIND:-}"
TIMEOUT="${TIMEOUT:-60}"
run_with_timeout() {
  if command -v timeout >/dev/null 2>&1; then
    timeout "$@"
  elif command -v gtimeout >/dev/null 2>&1; then
    gtimeout "$@"
  else
    local t=$1
    shift
    python3 -c '
import sys, subprocess
try:
    sys.exit(subprocess.run(sys.argv[2:], timeout=float(sys.argv[1])).returncode)
except subprocess.TimeoutExpired:
    sys.exit(124)
' "$t" "$@"
  fi
}
# PYC_FLAGS is prepended to every pyc invocation. Use it to drive
# a non-default backend / option across the whole suite without
# editing per-test sidecars, e.g. `PYC_FLAGS=-b ./test_pyc`
# to run with the LLVM backend (requires pyc built with USE_LLVM=1).
# See ifa/issues/013-pyc-llvm-default-off.md.
PYC_FLAGS="${PYC_FLAGS:-}"

# CI-mode gate: LLVM strict verifier (per-function verifyFunction
# on top of verifyModule, plus the .ll is written BEFORE the
# verifier runs so a failure leaves the broken IR on disk for
# post-mortem).  Harmless for the C backend.  Tests run with it
# enabled by default; opt out with `PYC_STRICT_VERIFY=0 ./test_pyc`.
export PYC_STRICT_VERIFY="${PYC_STRICT_VERIFY:-1}"
BUILD=tests/build
TESTS_DIR=tests

verbose=0
keep=0
bail=0
do_cpython=1
pattern=""

usage() {
  sed -n '2,28p' "$0" | sed 's/^# \{0,1\}//'
}

while [ $# -gt 0 ]; do
  case "$1" in
    -v|--verbose)    verbose=1 ;;
    -k|--keep)       keep=1 ;;
    -b|--bail)       bail=1 ;;
       --no-cpython) do_cpython=0 ;;
    -t|--timeout)    TIMEOUT="$2"; shift ;;
    -h|--help)       usage; exit 0 ;;
    --) shift; break ;;
    -*) echo "unknown option: $1" >&2; usage >&2; exit 2 ;;
    *)  pattern="$1" ;;
  esac
  shift
done

if [ ! -x "$PYC" ]; then
  echo "$PYC: not found or not executable. Run 'make' first." >&2
  exit 1
fi

cleanup() {
  if [ "$keep" = "0" ]; then rm -rf "$BUILD"; fi
}
trap cleanup EXIT

mkdir -p "$BUILD"
cp pyc_compat.py "$BUILD/"
# Stage all .py files as symlinks so cross-test imports resolve from inside
# the build dir without polluting the source tree.
for f in "$TESTS_DIR"/*.py; do ln -sf "../$(basename "$f")" "$BUILD/$(basename "$f")"; done

# Color output when stdout is a terminal.
if [ -t 1 ]; then
  R=$'\033[31m'; G=$'\033[32m'; Y=$'\033[33m'; B=$'\033[1m'; N=$'\033[0m'
else
  R=; G=; Y=; B=; N=
fi

passed=0
failed=0
expected_failed=0
skipped=0
failures=()

print_summary() {
  if [ "$verbose" != "1" ]; then printf '\n'; fi
  printf '\n%s---- summary ----%s\n' "$B" "$N"
  printf '  %spassed%s          %d\n' "$G" "$N" "$passed"
  printf '  %sexpected fails%s  %d\n' "$Y" "$N" "$expected_failed"
  printf '  %sfailed%s          %d\n' "$R" "$N" "$failed"
  printf '  skipped         %d\n' "$skipped"
  printf '  time            %ds\n' "$elapsed"
  if [ ${#failures[@]} -gt 0 ]; then
    printf '\n%sfailures:%s\n' "$R" "$N"
    for f in "${failures[@]}"; do printf '  %s\n' "$f"; done
  fi
}

note_failure() {
  failures+=("$1")
  failed=$((failed + 1))
  if [ "$bail" = "1" ]; then
    elapsed=$(( $(date +%s) - start ))
    print_summary
    exit 1
  fi
}

pass_log()    {
  if [ "$verbose" = "1" ]; then printf '  %s%s%s %s\n' "$G" "PASS" "$N" "$1"; else printf '%s.%s' "$G" "$N"; fi
}
skip_log()    {
  if [ "$verbose" = "1" ]; then printf '  %s%s%s %s\n' "$Y" "SKIP" "$N" "$1"; else printf '%ss%s' "$Y" "$N"; fi
}
xfail_log()   {
  if [ "$verbose" = "1" ]; then printf '  %s%s%s %s (%s)\n' "$Y" "XFAIL" "$N" "$1" "$2"; else printf '%sx%s' "$Y" "$N"; fi
}
fail_log()    {
  if [ "$verbose" = "1" ]; then
    printf '  %s%s%s %s (%s)\n' "$R" "FAIL" "$N" "$1" "$2" >&2
  else
    printf '\n  %s%s%s %s (%s)\n' "$R" "FAIL" "$N" "$1" "$2" >&2
  fi
}

start=$(date +%s)

for g in "$TESTS_DIR"/*.py; do
  name=$(basename "$g")
  base="${name%.py}"

  if [ -n "$pattern" ] && [[ "$name" != *"$pattern"* ]]; then continue; fi

  if [ -e "$g.ignore" ]; then
    skipped=$((skipped + 1)); skip_log "$name"; continue
  fi

  flags=
  [ -e "$g.flags" ] && flags=$(cat "$g.flags")

  # Compile.
  ( cd "$BUILD" && run_with_timeout "$TIMEOUT" $VALGRIND "../../$PYC" $PYC_FLAGS -D../.. $flags "$name" ) \
    > "$BUILD/$name.out" 2>&1
  rc=$?
  if [ $rc -eq 124 ]; then
    fail_log "$name" "COMPILE-TIMEOUT (${TIMEOUT}s)"
    note_failure "$name COMPILE-TIMEOUT  log: $BUILD/$name.out"
    continue
  fi

  if [ $rc -ne 0 ]; then
    if [ -e "$g.expect_fail" ]; then
      expected_failed=$((expected_failed + 1)); xfail_log "$name" "compile"; continue
    fi
    if [ -e "$g.check_fail" ]; then
      passed=$((passed + 1)); pass_log "$name (compile-fail-ok)"; continue
    fi
    fail_log "$name" "COMPILE"
    note_failure "$name COMPILE  log: $BUILD/$name.out"
    continue
  fi

  # Check compile-time stdout.
  check="$g.check"
  [ -e "$check" ] || check="$TESTS_DIR/empty"
  if ! diff -q "$BUILD/$name.out" "$check" > /dev/null 2>&1; then
    fail_log "$name" "COMPILE-OUT"
    diff "$BUILD/$name.out" "$check" | head -20 >&2
    note_failure "$name COMPILE-OUT  diff $BUILD/$name.out $check"
    continue
  fi

  # Execute, if exec.check exists.
  if [ ! -e "$g.exec.check" ]; then
    passed=$((passed + 1)); pass_log "$name (compile-only)"; continue
  fi

  ( cd "$BUILD" && run_with_timeout "$TIMEOUT" $VALGRIND ./"$base" ) \
    > "$BUILD/$name.exec.out" 2>&1
  rc=$?
  if [ $rc -eq 124 ]; then
    fail_log "$name" "EXEC-TIMEOUT (${TIMEOUT}s)"
    note_failure "$name EXEC-TIMEOUT  log: $BUILD/$name.exec.out"
    continue
  fi
  if [ $rc -ne 0 ] || ! diff -q "$BUILD/$name.exec.out" "$g.exec.check" > /dev/null 2>&1; then
    fail_log "$name" "EXEC"
    diff "$BUILD/$name.exec.out" "$g.exec.check" | head -20 >&2
    note_failure "$name EXEC  diff $BUILD/$name.exec.out $g.exec.check"
    continue
  fi

  # CPython cross-verify.
  if [ "$do_cpython" = "1" ]; then
    # PYTHONPATH=. so CPython finds pyc_compat.py in the build dir even
    # when the script is a symlink (Python resolves sys.path[0] from the
    # symlink target, not from cwd).
    ( cd "$BUILD" && PYTHONPATH=. run_with_timeout "$TIMEOUT" "$PYTHON" "$name" ) \
      > "$BUILD/$name.python.out" 2>&1
    if ! diff -q "$BUILD/$name.exec.out" "$BUILD/$name.python.out" > /dev/null 2>&1; then
      if [ -e "$g.python.expect_fail" ]; then
        expected_failed=$((expected_failed + 1)); xfail_log "$name" "cpython"; continue
      fi
      fail_log "$name" "CPYTHON"
      diff "$BUILD/$name.exec.out" "$BUILD/$name.python.out" | head -20 >&2
      note_failure "$name CPYTHON  diff $BUILD/$name.exec.out $BUILD/$name.python.out"
      continue
    fi
  fi

  passed=$((passed + 1)); pass_log "$name"
done

elapsed=$(( $(date +%s) - start ))
print_summary

if [ "$failed" -ne 0 ]; then exit 1; fi
exit 0
