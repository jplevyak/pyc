#!/bin/bash
# Rebless test outputs as the new expected baseline.
#
# Usage: ./baseline [pattern]
#
# After a `./test_pyc -k <pattern>` run that leaves outputs in tests/build/,
# this copies the current .out / .exec.out files into the corresponding
# .check / .exec.check files in tests/.
#
# Always inspect `git diff tests/` before committing.

set -euo pipefail

pattern="${1:-*}"
BUILD=tests/build
TESTS_DIR=tests

if [ ! -d "$BUILD" ]; then
  echo "$BUILD/ not found; run './test_pyc -k $pattern' first" >&2
  exit 1
fi

changed=0
for f in "$BUILD"/$pattern.py.out; do
  [ -e "$f" ] || continue
  name=$(basename "$f" .out)
  target="$TESTS_DIR/$name.check"
  if [ -e "$TESTS_DIR/${name%.out}" ] || [ -s "$f" ]; then
    cp "$f" "$target"
    changed=$((changed + 1))
    echo "blessed: $target"
  fi
done

for f in "$BUILD"/$pattern.py.exec.out; do
  [ -e "$f" ] || continue
  name=$(basename "$f" .out)
  target="$TESTS_DIR/${name}.check"
  cp "$f" "$target"
  changed=$((changed + 1))
  echo "blessed: $target"
done

echo "---"
echo "$changed file(s) updated. Review with 'git diff $TESTS_DIR/' before committing."
