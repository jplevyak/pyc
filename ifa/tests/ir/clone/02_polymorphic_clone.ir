;; 02_polymorphic_clone.ir — %id called with int32 and float64.
;; FA splits into two ESes; clone(fa) should produce one cloned Fun
;; for the second ES, giving two distinct Funs in pdb->funs after
;; clone.
;;
;; Expected: funs >= 2 after clone (original %id + clone), and the
;; cloned Fun appears in (new-funs).

(sym %k_i :is-constant :immediate (int32 1))
(sym %k_f :is-constant :immediate (float64 2.5))

(sym %x :is-local)
(sym %r :is-local)
(sym %icont)
(fun %id
  :args (%id %x)
  :rets (%r)
  :cont %icont
  :body (move %x %r))

(sym %r1 :is-local)
(sym %r2 :is-local)
(sym %tcont)
(fun %top
  :rets (%r1)
  :cont %tcont
  :body
    (send %id %k_i => %r1)
    (send %id %k_f => %r2))

(entry %top)
