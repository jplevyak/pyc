;; 01_monomorphic.ir — single call site, single concrete type.
;; clone(fa) should produce no new Funs; %add stays as one Fun.
;; Each CS is in its own equivalence class.

(sym %k1 :is-constant :immediate (int32 1))
(sym %k2 :is-constant :immediate (int32 2))

(sym %a :is-local)
(sym %b :is-local)
(sym %ar :is-local)
(sym %acont)
(fun %add
  :args (%add %a %b)
  :rets (%ar)
  :cont %acont
  :body (move %a %ar))

(sym %r :is-local)
(sym %tcont)
(fun %top
  :rets (%r)
  :cont %tcont
  :body (send %add %k1 %k2 => %r))

(entry %top)
