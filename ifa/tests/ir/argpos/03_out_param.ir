;; 03_out_param.ir — second arg is an OUT parameter. Expected: pos[2]
;; carries the :out annotation, and the corresponding MPosition
;; appears in `out_positions`.

(sym %a :is-local)
(sym %b :is-local :intent OUT)
(sym %r :is-local)
(sym %cont)

(fun %storeb
  :args (%a %b)
  :rets (%r)
  :cont %cont
  :body
    (move %a %b))

(entry %storeb)
