;; 02_unused_fun.ir — %ghost is declared and registered, but never
;; called from %top. After mark_live_funs, %ghost should be marked
;; dead.

(sym %k :is-constant :immediate (int32 1))

(sym %ga :is-local)
(sym %gr :is-local)
(sym %gcont)
(fun %ghost
  :args (%ghost %ga)
  :rets (%gr)
  :cont %gcont
  :body (move %ga %gr))

(sym %a :is-local)
(sym %ar :is-local)
(sym %acont)
(fun %live_fn
  :args (%live_fn %a)
  :rets (%ar)
  :cont %acont
  :body (move %a %ar))

(sym %r :is-local)
(sym %tcont)
(fun %top
  :rets (%r)
  :cont %tcont
  :body (send %live_fn %k => %r))

(entry %top)
