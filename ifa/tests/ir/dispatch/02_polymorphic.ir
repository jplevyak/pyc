;; 02_polymorphic.ir — %id called with int32 and float64. Each call
;; site dispatches into a separate %id specialization.
;;
;; Expected: @__main__#0 shows two SENDs, each with its own outgoing
;; edge → %id#0 and %id#1 respectively; arg filters differ.

(sym %k_i :is-constant :immediate (int32 1))
(sym %k_f :is-constant :immediate (float64 2.5))

(sym %x :is-local)
(sym %r :is-local)
(sym %icont)
(fun %id
  :args (%id %x)
  :rets (%r)
  :cont %icont
  :body
    (move %x %r))

(sym %r1 :is-local)
(sym %r2 :is-local)
(sym %tcont)
(fun %top
  :rets (%r1)
  :cont %tcont
  :body
    (send %id %k_i => %r1)
    (send %id %k_f => %r2))

(entry %top)
