;; 01_simple.ir — single call to %add. The dispatch printer should
;; show @__main__#0's outgoing edge to %add#0 with the int32-typed
;; arg filter.

(sym %k1 :is-constant :immediate (int32 1))
(sym %k2 :is-constant :immediate (int32 2))

(sym %a :is-local)
(sym %b :is-local)
(sym %ar :is-local)
(sym %acont)

(fun %add
  :args (%add %a %b)
  :rets (%ar)
  :cont %acont
  :body
    (move %a %ar))

(sym %r :is-local)
(sym %tcont)
(fun %top
  :rets (%r)
  :cont %tcont
  :body
    (send %add %k1 %k2 => %r))

(entry %top)
