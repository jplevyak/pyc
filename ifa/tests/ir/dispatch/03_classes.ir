;; 03_classes.ir — class allocation + dispatch on a setter call.
;; Demonstrates the dispatch printer over primitive sends (those go
;; "off-graph" — they don't produce AEdges to other Funs, so the
;; printer shows them with no `→` line, just the SEND form).

(type %Point :kind RECORD :has (%px))
(sym %px :in %Point)

(sym %k :is-constant :immediate (int32 42))

(sym %obj :is-local)
(sym %sa :is-local)
(sym %r :is-local)
(sym %tcont)

(fun %top
  :rets (%r)
  :cont %tcont
  :body
    (send @primitive @new %Point => %obj)
    (send @operator %obj @setter #px %k => %sa)
    (send @operator %obj @period #px => %r))

(entry %top)
