;; 01_baseline.ir — minimum codegen test. After full ifa pipeline,
;; the C backend emits the .c file. The golden captures whatever
;; comes out (modulo stripping `#include "c_runtime.h"`).

(sym %k :is-constant :immediate (int32 42))

(sym %x :is-local)
(sym %r :is-local)
(sym %tcont)
(fun %top
  :rets (%r)
  :cont %tcont
  :body
    (move %k %x)
    (move %x %r))

(entry %top)
