;; 09_ssu_self_binding.ir — pinpoint the SSU formal-arg → renamed-local
;; binding gap from issue 016.
;;
;; Reproduces the iterator-style shape from `range::__pyc_more__`:
;; a function takes a record-typed formal arg (`%self`), then accesses
;; a field on it. After SSU, the formal arg's Var may get renamed; the
;; MOVE that should bind `%self` → its renamed local has
;; `live=1, fa_live=0` (or `0, 1` depending on what DCE / FA see) and
;; the LLVM backend's `live && fa_live` gate (llvm_codegen.cc) drops
;; the MOVE entirely. The renamed local stays uninitialized, the GEP
;; reads garbage, and iterator-style loops never terminate.
;;
;; Pre-CG_IR LLVM golden:
;;   - `%accessor` (or its monomorphized form) has an alloca for the
;;     SSU-renamed receiver but NO store from the formal arg.
;;   - GEPs read from the uninitialized alloca.
;;
;; Post-CG_IR (Phase 3.3) LLVM golden:
;;   - The alloca is stored to from the formal arg at function entry
;;     (cg_normalize emits an explicit CG_STORE that doesn't go through
;;     the live gate).
;;   - GEPs land on a real pointer.
;;
;; If DCE elides the visible side effect, the fixture is still useful
;; as input-DSL documentation and as a regression marker for the
;; codegen-llvm fixture surface. The structural shape — a
;; function-with-formal-arg followed by an immediate field access — is
;; what matters; the golden locks in whatever the backend emits.

(type %Box :kind RECORD :has (%v))
(sym %v :in %Box)

(sym %k :is-constant :immediate (int32 42))

(sym %a :is-local)
(sym %ar :is-local)
(sym %acont)
(fun %accessor
  :args (%accessor %a)
  :rets (%ar)
  :cont %acont
  :body
    (send @operator %a @period #v => %ar))

(sym %p :is-local)
(sym %s :is-local)
(sym %r :is-local)
(sym %tcont)
(fun %top
  :rets (%r)
  :cont %tcont
  :body
    (send @primitive @new %Box => %p)
    (send @operator %p @setter #v %k => %s)
    (send %accessor %p => %r))

(entry %top)
