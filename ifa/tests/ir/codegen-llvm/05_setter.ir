;; 03_setter.ir — pinpoint the P_prim_setter codegen path.
;;
;; Builds a record %Point with one int32 field %px, allocates an
;; instance %p, and writes %k (int32) into %p.px via the setter
;; primitive. The lvalue %s receives the val per issue 011's
;; Option A (analyzer's flow_vars(val, result) — codegen emits
;; `t = (val_type)val`).
;;
;; The golden locks in:
;;   - the `_CG_int64 t3 = (_CG_int64)t2;` lvalue assignment
;;     pattern (val cast through lvals[0]'s declared type)
;;   - that the receiver write `((_CG_ps...)t1)->e0 = ...` happens
;;     immediately before the lvalue assignment
;;   - that DCE doesn't elide the setter when its lvalue %s is
;;     consumed by `move %s %r`
;;
;; If issue 011 ever regresses to the receiver-emit form
;; (`t3 = ((_CG_ps...)t1)`), this fixture's golden will shift.

(type %Point :kind RECORD :has (%px))
(sym %px :in %Point)

(sym %k :is-constant :immediate (int32 42))

(sym %p :is-local)
(sym %s :is-local)
(sym %r :is-local)
(sym %tcont)
(fun %top
  :rets (%r)
  :cont %tcont
  :body
    (send @primitive @new %Point => %p)
    (send @operator %p @setter #px %k => %s)
    (move %s %r))

(entry %top)
