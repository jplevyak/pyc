;; 03_record_with_field.ir — allocate a single record, set a field.
;; Exercises the LLVM backend's struct codegen + field setter path.

(type %Point :kind RECORD :has (%px))
(sym %px :in %Point)

(sym %k :is-constant :immediate (int32 42))

(sym %p :is-local)
(sym %s :is-local)
(sym %r :is-local)
(sym %tcont)
(fun %top
  :rets (%r)
  :cont %tcont
  :body
    (send @primitive @new %Point => %p)
    (send @operator %p @setter #px %k => %s)
    (move %p %r))

(entry %top)
