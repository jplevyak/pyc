;; 10_class_instance.ir — declare a %Point RECORD type, two field
;; Syms, and a function that takes a %Point-typed formal.
;;
;; What this DOES test:
;;   - The .ir parser handles `(type %Foo :kind RECORD :has ...)`.
;;   - `:must-specialize %UserType` resolves to a user-defined
;;     class (not just builtin types like @int32).
;;   - FA's initialize_Sym_for_fa creates a CreationSet for %Point
;;     (since type_kind=Type_RECORD) — visible as +1 in css count.
;;
;; What this does NOT test (deferred, see phase 05 §7):
;;   - Actually allocating an instance. pyc binds `new_object` via
;;     prelude.v's `new(a:anytype)` function — without prelude.v,
;;     the test harness has no allocator. So %use_point is registered
;;     but FA never dispatches into it (the caller can't construct a
;;     %Point value to flow in).
;;   - Field setter/getter primitives (sym_setter, sym_period) need
;;     transfer functions registered via FA::register_primitive.
;;     prelude.v's `operator(...)` patterns provide these in pyc.
;;
;; This fixture exists as a smoke test that the type-system bits of
;; the .ir parser work for user-defined classes. A follow-up needs a
;; minimal `#__new` primitive in fa_setup to actually allocate.

(type %Point :kind RECORD :has (%px %py))
(sym %px :in %Point)
(sym %py :in %Point)

;; A "point" — referenced as an instance to seed FA. With
;; :must-specialize, the formal dispatches on the %Point type.
(sym %pt :is-local :must-specialize %Point)
(sym %r :is-local)
(sym %acont)
(fun %use_point
  :args (%use_point %pt)
  :rets (%r)
  :cont %acont
  :body
    (move %pt %r))

;; An instance: a Var that we declare as belonging to %Point. FA's
;; initialize_Sym_for_fa will give %Point an abstract_type with one
;; CS, which flows through %inst's AVar.
(sym %inst :is-local :type %Point)
(sym %r_top :is-local)
(sym %tcont)
(fun %top
  :rets (%r_top)
  :cont %tcont
  :body
    (send %use_point %inst => %r_top))

(entry %top)
