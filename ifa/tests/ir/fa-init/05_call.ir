;; 05_call.ir — top SENDs to %add with two int32 constants.
;;
;; Closure-receiver convention: %add takes itself as its own first
;; formal arg (matches pyc's `if1_closure(if1, fn, code, 1, &fn)`).
;; The SEND's rval[0] is the receiver, which lines up with formal
;; pos[1] = %add.
;;
;; Expected: FA produces two EntrySets — @__main__ AND %add — because
;; the SEND actually dispatches into %add. The run_one harness sets
;; partial_default = Partial_NEVER, otherwise the dispatch would be
;; routed into make_closure() (partial application path) and trip
;; its `contour_is_entry_set` assertion.

(sym %k1 :is-constant :immediate (int32 1))
(sym %k2 :is-constant :immediate (int32 2))

(sym %a :is-local)
(sym %b :is-local)
(sym %ar :is-local)
(sym %acont)

(fun %add
  :args (%add %a %b)
  :rets (%ar)
  :cont %acont
  :body
    (move %a %ar))

(sym %r :is-local)
(sym %tcont)

(fun %top
  :rets (%r)
  :cont %tcont
  :body
    (send %add %k1 %k2 => %r))

(entry %top)
