;; 04_polymorphic.ir — %id called with two distinct types.
;; FA splits into two EntrySets per the type-divergence rule.
;; Phase 4 verifies that the per-Fun arg_escapes signature is
;; the JOIN across both EntrySets (project_to_fun's behavior).
;;
;; This is the natural shape where Phase 4 cloning *could*
;; fire if escape diverged across the two EntrySets — for
;; this all-scalar IR it doesn't (both stay NoEscape), but
;; the fixture documents the ess=2 shape so a future Phase 6
;; iteration that introduces real escape divergence here
;; will produce a visible diff.

(sym %k_i :is-constant :immediate (int32 1))
(sym %k_f :is-constant :immediate (float64 2.5))

(sym %x :is-local)
(sym %r :is-local)
(sym %icont)
(fun %id
  :args (%id %x)
  :rets (%r)
  :cont %icont
  :body (move %x %r))

(sym %r1 :is-local)
(sym %r2 :is-local)
(sym %tcont)
(fun %top
  :rets (%r1)
  :cont %tcont
  :body
    (send %id %k_i => %r1)
    (send %id %k_f => %r2))

(entry %top)
