;; 01_monomorphic.ir — single call to %add with int args.
;; Phase 2-4 baseline: %add's formals %a and %b are ints
;; (non-ptr), so escape is meaningless for them.  Verifies
;; that escape analysis runs to completion and produces a
;; sensible per-formal signature even on trivial input.

(sym %k1 :is-constant :immediate (int32 1))
(sym %k2 :is-constant :immediate (int32 2))

(sym %a :is-local)
(sym %b :is-local)
(sym %ar :is-local)
(sym %acont)
(fun %add
  :args (%add %a %b)
  :rets (%ar)
  :cont %acont
  :body (move %a %ar))

(sym %r :is-local)
(sym %tcont)
(fun %top
  :rets (%r)
  :cont %tcont
  :body (send %add %k1 %k2 => %r))

(entry %top)
