;; 02_identity.ir — %id has body `move arg → ret`.  Without
;; an explicit reply in the fixture, the IF1 fa_setup auto-
;; adds a reply only for sym___main__.  %id's body therefore
;; doesn't include the prim_reply that would force its `%a`
;; formal to Escape.  Phase 2's transfer should still mark
;; the move's destination escape as the source's.

(sym %k :is-constant :immediate (int32 7))

(sym %a :is-local)
(sym %r :is-local)
(sym %icont)
(fun %id
  :args (%id %a)
  :rets (%r)
  :cont %icont
  :body
    (move %a %r))

(sym %tr :is-local)
(sym %tcont)
(fun %top
  :rets (%tr)
  :cont %tcont
  :body
    (send %id %k => %tr))

(entry %top)
