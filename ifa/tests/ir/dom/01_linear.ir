;; 01_linear.ir — straight-line body; idom is a simple chain.
;;
;; Expected: each PNode is dominated by its single CFG predecessor.
;; rdom: each PNode is post-dominated by its single CFG successor.
;; frontier: empty everywhere (no joins).

(sym %a :is-local)
(sym %b :is-local)
(sym %r :is-local)
(sym %cont)

(fun %chain
  :args (%a %b)
  :rets (%r)
  :cont %cont
  :body
    (move %a %r)
    (move %b %r))

(entry %chain)
