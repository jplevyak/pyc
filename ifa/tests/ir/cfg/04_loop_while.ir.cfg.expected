;; phase: cfg

;; Fun %while
(fun %while
  entry:  %p0
  exit:   %p6
  pnodes: 7
)
(pnodes %while
  %p0  NOP    succ:[%p1]
  %p1  LABEL  succ:[%p2]  pred:[%p0 %p5]
  %p2  IF    %cond  succ:[%p3 %p6]  pred:[%p1]
  %p3  LABEL  succ:[%p4]  pred:[%p2]
  %p4  MOVE  %i -> %r  succ:[%p5]  pred:[%p3]
