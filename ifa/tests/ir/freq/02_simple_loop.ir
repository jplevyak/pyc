;; 02_simple_loop.ir — a while-shaped loop in %top. PNodes inside
;; the loop body should get an execution_frequency of LOOP_FREQUENCY
;; (=10.0); outside, 1.0.

(sym %k :is-constant :immediate (int32 1))
(sym %cond :is-local)
(sym %x :is-local)
(sym %r :is-local)
(sym %tcont)

(fun %top
  :rets (%r)
  :cont %tcont
  :body
    (move %k %x)
    (label %L_top)
    (if %cond %L_body %L_end)
    (label %L_body)
    (move %x %r)
    (goto %L_top)
    (label %L_end))

(entry %top)
