;; 01_simple_send.ir
;;
;; Minimal closure: %add takes two args, sends them, returns the
;; result. Exercises the finalize pipeline:
;;   - set-top: makes %add the program's top symbol
;;   - bind-prims: SEND opcodes get their `prim` slot resolved (none here
;;     — the args carry no operator binding, so prim stays unset)
;;   - dce: every reachable Sym/Code stays live
;;   - flatten: nested SEQ/CONC structure normalized
;;
;; A second function %ignored is declared but never made the entry — DCE
;; should drop it (or at least the printer should report it as dead).

(sym %a :is-local)
(sym %b :is-local)
(sym %r :is-local)
(sym %cont)
(sym %ret)

(fun %add
  :args (%a %b)
  :rets (%r)
  :cont %cont
  :body
    (send %a %b => %r)
    (label %L_end))

(sym %u :is-local)
(sym %v :is-local)
(sym %dead_cont)
(fun %ignored
  :args (%u)
  :rets (%v)
  :cont %dead_cont
  :body
    (move %u %v)
    (label %L_dead))

(entry %add)
