;; phase: patterns

(mtype %V
  pos["self"]: %__getitem__ %__setitem__
  pos[2]: %__getitem__ %__setitem__
)

(mtype %__getitem__
  pos["__getitem__"]: %__getitem__
  pos[1]: %__getitem__
)

(mtype #__getitem__
  pos[1]: %__getitem__
)

(mtype %__setitem__
  pos["__setitem__"]: %__setitem__
  pos[1]: %__setitem__
)

(mtype #__setitem__
  pos[1]: %__setitem__
)

(mtype @any
  pos["i"]: %__getitem__ %__setitem__
  pos["val"]: %__setitem__
  pos[3]: %__getitem__ %__setitem__
  pos[4]: %__setitem__
)

(mtype #top
  pos[1]: %top
)

(mtype %top
  pos["top"]: %top
  pos[1]: %top
)

