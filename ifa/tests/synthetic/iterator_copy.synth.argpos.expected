;; phase: argpos

;; Fun %copy
(positions %copy
  pos["dst"] -> %dst :alias-of pos[3]
  pos["src"] -> %src :alias-of pos[2]
  pos[1] -> #copy :positional
  pos[2] -> %src :positional
  pos[3] -> %dst :positional
  rets: %t4
)

;; Fun %next
(positions %next
  pos["self"] -> %self :alias-of pos[2]
  pos[1] -> #next :positional
  pos[2] -> %self :positional
  rets: %t2
)

;; Fun %top
(positions %top
  pos[1] -> #top :positional
  rets: %t9
)

