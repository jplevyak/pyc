;; phase: argpos

;; Fun %make_t
(positions %make_t
  pos["v"] -> %v :alias-of pos[2]
  pos[1] -> #make_t :positional
  pos[2] -> %v :positional
  rets: %t3
)

;; Fun %relay2
(positions %relay2
  pos["x"] -> %x :alias-of pos[2]
  pos[1] -> #relay2 :positional
  pos[2] -> %x :positional
  rets: %t1
)

;; Fun %top
(positions %top
  pos[1] -> #top :positional
  rets: %t7
)

