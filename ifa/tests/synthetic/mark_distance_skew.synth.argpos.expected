;; phase: argpos

;; Fun %relay
(positions %relay
  pos["x"] -> %x :alias-of pos[2]
  pos[1] -> #relay :positional
  pos[2] -> %x :positional
  rets: %t1
)

;; Fun %sink
(positions %sink
  pos["y"] -> %y :alias-of pos[2]
  pos[1] -> #sink :positional
  pos[2] -> %y :positional
  rets: %t3
)

;; Fun %top
(positions %top
  pos[1] -> #top :positional
  rets: %t5
)

